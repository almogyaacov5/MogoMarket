<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_login_card"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- כותרת -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שאל את ה-AI"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E5E7EB"
            android:layout_gravity="center_horizontal"
            android:letterSpacing="0.05"
            android:paddingBottom="6dp" />

        <!-- תת כותרת -->
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 דוגמאות: 'מה דעתך על השקעה קצרת טווח?' או 'האם לקנות עכשיו?'"
            android:textSize="13sp"
            android:textColor="#B6C2D1"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <!-- שדה הקלדה -->
        <EditText
            android:id="@+id/et_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="הקלד שאלה..."
            android:textSize="15sp"
            android:textColor="#E5E7EB"
            android:textColorHint="#7B8AA0"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:inputType="textMultiLine|textCapSentences" />

        <!-- קו הפרדה -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2F1F9990"
            android:layout_marginBottom="20dp" />

        <!-- כפתור שליחה -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="שלח ל-AI"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#329763"
            android:stateListAnimator="@null" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_ai"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:indeterminateTint="#329763" />

        <!-- תשובת AI -->
        <TextView
            android:id="@+id/tv_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#E5E7EB"
            android:padding="14dp"
            android:layout_marginTop="12dp"
            android:background="#1A329763"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
