<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chartRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    tools:context=".MainActivity">

    <!-- ===== HEADER: Financial Terminal Top Bar ===== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp">

        <!-- Row 1: Ticker + Price -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tickerText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-- / --"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="0.02"/>

            <!-- 🌙☀️ כפתור מצב כהה/בהיר -->
            <ImageButton
                android:id="@+id/btnThemeToggle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/baseline_brightness_2_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle theme"
                android:tint="@color/text_secondary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/priceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.02"/>
        </LinearLayout>

        <!-- Row 2: Daily Change -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/changeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="14sp"
                android:textColor="@color/gain"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <TextView
                android:id="@+id/currentPriceDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== SEARCH ROW ===== -->
    <LinearLayout
        android:id="@+id/searchSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatAutoCompleteTextView
            android:id="@+id/ticker_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Enter a ticker"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp"
            android:background="@color/bg_card"
            android:elevation="2dp"
            android:inputType="text"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:textDirection="ltr"
            android:popupBackground="@color/bg_card"
            android:layout_marginEnd="10dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLoad"
            android:layout_width="110dp"
            android:layout_height="48dp"
            android:text="OPEN"
            android:textColor="@color/bg_primary"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:stateListAnimator="@null"
            android:elevation="2dp"/>
    </LinearLayout>

    <!-- ===== CONTROLS ROW ===== -->
    <LinearLayout
        android:id="@+id/controlsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:background="@color/bg_card"
        android:padding="10dp"
        android:layoutDirection="ltr">

        <ImageButton
            android:id="@+id/btnChartRefresh"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/main_refresh_button"
            android:contentDescription="רענן"
            android:src="@drawable/baseline_refresh_24"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSelectTimeFrame"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Time frame"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/primary"
            android:paddingHorizontal="12dp"
            android:layout_marginStart="10dp"
            android:stateListAnimator="@null"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnToggleChart"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Line chart"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/primary_dark"
            android:paddingHorizontal="12dp"
            android:layout_marginStart="10dp"
            android:stateListAnimator="@null"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAIAnalysis"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="AI"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/gain"
            android:paddingHorizontal="12dp"
            android:layout_marginStart="10dp"
            android:stateListAnimator="@null"/>

        <!-- 🔲 כפתור הגדלת גרף -->
        <ImageButton
            android:id="@+id/btnExpandChart"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/baseline_fullscreen_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="הגדל גרף"
            android:tint="@color/text_secondary"
            android:layout_marginStart="10dp"/>

        <ProgressBar
            android:id="@+id/progressAI"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- ===== AXIS ZOOM CONTROLS ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:background="@color/bg_card"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zoom:"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAxisBoth"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⊞ Both"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary"
            android:paddingHorizontal="12dp"
            android:layout_marginEnd="6dp"
            android:stateListAnimator="@null"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAxisX"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="↔ X"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/bg_secondary"
            android:paddingHorizontal="12dp"
            android:layout_marginEnd="6dp"
            android:stateListAnimator="@null"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAxisY"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="↕ Y"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/bg_secondary"
            android:paddingHorizontal="12dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- ===== CHART AREA ===== -->
    <FrameLayout
        android:id="@+id/chartContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:background="@color/bg_card"
        android:padding="4dp">

        <com.github.mikephil.charting.charts.CandleStickChart
            android:id="@+id/stock_chart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_card"/>

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/line_chart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_card"
            android:visibility="gone"/>

        <!-- כפתור יציאה ממסך מלא -->
        <ImageButton
            android:id="@+id/btnExitFullscreen"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/baseline_fullscreen_exit_24"
            android:background="#AA151C2E"
            android:tint="@color/text_primary"
            android:contentDescription="צא ממסך מלא"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- ===== BOTTOM INFO BAR ===== -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/timeFrameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Timeframe: --"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H: --"
            android:textSize="12sp"
            android:textColor="@color/gain"
            android:layout_marginEnd="12dp"
            android:letterSpacing="0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L: --"
            android:textSize="12sp"
            android:textColor="@color/loss"
            android:letterSpacing="0.02"/>
    </LinearLayout>

</LinearLayout>
