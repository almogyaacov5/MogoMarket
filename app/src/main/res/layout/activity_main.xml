<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#1E3A5F"
        android:elevation="12dp">

        <!-- Chart -->
        <LinearLayout
            android:id="@+id/nav_btn_chart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_chart"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_chart"
                android:contentDescription="Chart" />
            <TextView
                android:id="@+id/nav_label_chart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chart"
                android:textSize="10sp"
                android:textColor="#80B8D4"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Watchlist -->
        <LinearLayout
            android:id="@+id/nav_btn_stocks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_stocks"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_watchlist"
                android:contentDescription="Watchlist" />
            <TextView
                android:id="@+id/nav_label_stocks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Watchlist"
                android:textSize="10sp"
                android:textColor="#80B8D4"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Portfolio -->
        <LinearLayout
            android:id="@+id/nav_btn_portfolio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_portfolio"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_portfolio"
                android:contentDescription="Portfolio" />
            <TextView
                android:id="@+id/nav_label_portfolio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Portfolio"
                android:textSize="10sp"
                android:textColor="#80B8D4"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Closed Trades -->
        <LinearLayout
            android:id="@+id/nav_btn_closed"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_closed"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_closed"
                android:contentDescription="Closed Trades" />
            <TextView
                android:id="@+id/nav_label_closed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Closed"
                android:textSize="10sp"
                android:textColor="#80B8D4"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Simulator -->
        <LinearLayout
            android:id="@+id/nav_btn_simulator"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_simulator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_simulator"
                android:contentDescription="Simulator" />
            <TextView
                android:id="@+id/nav_label_simulator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sim"
                android:textSize="10sp"
                android:textColor="#80B8D4"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/nav_btn_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_settings"
                android:contentDescription="Settings" />
            <TextView
                android:id="@+id/nav_label_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="10sp"
                android:textColor="#80B8D4"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
