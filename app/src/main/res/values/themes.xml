<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.Chart" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/colorTextOnPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/colorTextOnPrimary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorBackground">@color/colorBackground</item>
        <item name="colorOnBackground">@color/colorTextPrimary</item>
        <item name="colorOnSurfaceVariant">@color/colorTextSecondary</item>
        <item name="colorError">@color/colorLoss</item>
        <item name="colorOnError">@color/white</item>
        <item name="materialCardViewStyle">@style/CardStyle</item>
        <item name="android:statusBarColor">@color/colorNavBar</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Chart" parent="Base.Theme.Chart" />

    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/colorCard</item>
        <item name="strokeColor">@color/colorCardStroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>
