<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.Chart" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/bg_card</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorError">@color/loss</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="materialCardViewStyle">@style/CardStyle</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Chart" parent="Base.Theme.Chart" />

    <!-- תאימות לשם Theme.MogoMarket -->
    <style name="Theme.MogoMarket" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/bg_card</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorError">@color/loss</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="materialCardViewStyle">@style/CardStyle</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- סטייל כרטיס - Premium Dark Card -->
    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/colorDivider</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">6dp</item>
    </style>

    <!-- סטייל כפתור - Trading Style -->
    <style name="ButtonStyle" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- סטייל כפתור שני - Outlined -->
    <style name="ButtonOutlinedStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- סטייל טקסט - Gain (ירוק) -->
    <style name="TextGain">
        <item name="android:textColor">@color/gain</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- סטייל טקסט - Loss (אדום) -->
    <style name="TextLoss">
        <item name="android:textColor">@color/loss</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
